# Wallet seed configuration
# Copy this to .env.seed and fill in your values.
# .env.seed is gitignored and will not be committed.

# Password for the wallet vault
SEED_PASSWORD=

# 12-word BIP39 mnemonic (space-separated)
SEED_MNEMONIC=

# Network: testnet | mainnet | futurenet | custom
SEED_NETWORK=testnet

# Privacy channel contract ID
SEED_CHANNEL_CONTRACT_ID=CDMZSHMT2AIL2UG7XBOHZKXM6FY3MUP75HAXUUSAHLGRQ2VWPGYKPM5T

# Channel name (for display)
SEED_CHANNEL_NAME=Moonlight Beta

# Asset code (e.g., XLM)
SEED_ASSET_CODE=XLM

# Asset issuer (leave empty for native XLM)
SEED_ASSET_ISSUER=

# Privacy providers (comma-separated name=url pairs)
SEED_PROVIDERS=Provider B=https://moonlight-beta-privacy-provider-b.fly.dev,Provider A=https://moonlight-beta-privacy-provider-a.fly.dev
